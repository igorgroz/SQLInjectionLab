# backend/.npmrc
# legacy-peer-deps resolves the conflict between:
#   express-graphql@0.12.0  → requires graphql@^15
#   @apollo/server@4.x      → requires graphql@^16
# Both packages are in use: express-graphql for the insecure/secure GraphQL
# training endpoints, @apollo/server v4 for the migrated /graphql endpoint.
# The graphql v16 API used by both is backwards-compatible in practice.
# TODO: migrate express-graphql → graphql-http to remove this conflict.
legacy-peer-deps=true
